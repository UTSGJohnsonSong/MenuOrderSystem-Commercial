# ── 数据库 ──
# 本地开发：docker run -d --name menudb -p 5432:5432 -e POSTGRES_PASSWORD=dev postgres:16-alpine
DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres

# ── 短信验证码 ──
# console = 不真发短信，验证码打印在服务器日志 / 开发模式下直接显示在登录页（仅限开发）
# tencent = 腾讯云短信（推荐：服务器/域名/备案同账号）
# aliyun  = 阿里云短信
SMS_PROVIDER=console

# 腾讯云短信（SMS_PROVIDER=tencent 时必填；子账号只授权 QcloudSMSFullAccess）
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
# TENCENT_SMS_REGION=ap-guangzhou

# 阿里云短信（SMS_PROVIDER=aliyun 时必填）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# ── 图片存储目录（默认 ./uploads，Docker 里是持久卷 /app/uploads）──
# UPLOAD_DIR=

# ── ICP 备案号（备案下来后填，会显示在落地页底部）──
NEXT_PUBLIC_ICP_NUMBER=

# ── 管理员手机号白名单（逗号分隔多个）。这些账号登录后可访问 /admin 管理后台 ──
ADMIN_PHONES=

# ── docker-compose 用 ──
DB_PASSWORD=
